<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MostWanted.LayoutExample"
             Title="LayoutExample">
    <VerticalStackLayout x:Name="VStackLayout" Padding="{OnPlatform iOS='30,10,30,10',Default=30 }"
        BackgroundColor="{OnPlatform iOS=Green,Android=AliceBlue}">
        <Label 
            Text="Welcome To Most Wanted"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
        <Grid ColumnDefinitions="Auto,30,Auto">
            <Button Grid.Column="0" Text="Most Wanted" WidthRequest="100"/>


        </Grid>
   
   
    </VerticalStackLayout>
</ContentPage>